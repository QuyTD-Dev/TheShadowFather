--- !u!114 &1625480154151733002
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 7189218356587766445}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4064c7635c5c2994ca7ddc0fbda33efe, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NPCInteract
  conversation:
  - speakerName: Player
    sentence: "Aria! Con sao r\u1ED3i? L\u1EDBp v\u1EA3y \u0111\xE1 n\xE0y... n\xF3
      \u0111\xE3 lan l\xEAn t\u1EADn c\u1ED5 con r\u1ED3i!"
  - speakerName: Aria
    sentence: "(Th\u1EC1u th\xE0o)... Cha \u01A1i... Con l\u1EA1nh qu\xE1... C\u1EA3m
      gi\xE1c nh\u01B0 m\xE1u trong ng\u01B0\u1EDDi \u0111ang \u0111\xF4ng c\u1EE9ng
      l\u1EA1i..."
  - speakerName: Player
    sentence: "\u0110\u1EEBng s\u1EE3, cha \u0111\xE3 t\xECm \u0111\u01B0\u1EE3c
      c\xE1ch r\u1ED3i. Madam Yaga n\xF3i ch\u1EC9 c\u1EA7n c\xF3 Huy\u1EBFt Th\u1EA3o,
      b\xE0 \u1EA5y s\u1EBD c\u1EE9u \u0111\u01B0\u1EE3c con."
  - speakerName: Aria
    sentence: "Khu R\u1EEBng \u0110ang Ch\u1EBFt... n\u01A1i \u0111\xF3 \xE1c qu\u1EF7
      nhi\u1EC1u l\u1EAFm... Nh\u1EE1 cha c\xF3 m\u1EC7nh h\u1EC7 n\xE0o..."
  - speakerName: Player
    sentence: "Cha th\xE0 n\u1ED9p m\u1EA1ng cho l\u0169 \xE1c qu\u1EF7 ngo\xE0i
      kia c\xF2n h\u01A1n l\xE0 m\u1EA5t con. C\u1ED1 g\u1EAFng th\u1EE9c \u0111\u1EE3i
      cha nh\xE9, cha s\u1EBD v\u1EC1 nhanh th\xF4i!"
  delayBetweenLines: 3
  dialoguePanel: {fileID: 0}
  dialogueText: {fileID: 0}
