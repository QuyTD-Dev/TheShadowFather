--- !u!114 &4905000806661230148
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 6118463472905898820}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4064c7635c5c2994ca7ddc0fbda33efe, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NPCInteract
  conversation:
  - speakerName: Kael
    sentence: "C\u1EA9n th\u1EADn c\xE1i l\xF2, l\u1EEF kh\xE1ch! S\u1EE9c n\xF3ng
      n\xE0y gi\u1EEF c\xE1i l\xE0ng kh\u1ECFi b\u1ECB \u0111\xF3ng b\u0103ng."
  - speakerName: Player
    sentence: "Thanh ki\u1EBFm c\u1EE7a t\xF4i c\xF3 v\u1EBB kh\xF4ng ch\u1ECBu n\u1ED5i
      c\xE1i l\u1EA1nh n\xE0y n\u1EEFa r\u1ED3i."
  - speakerName: Kael
    sentence: "N\xF3 m\u1EBB r\u1ED3i. \u1EDE v\xF9ng \u0111\u1EA5t n\xE0y, v\u0169
      kh\xED c\xF9n ngh\u0129a l\xE0 c\xE1i ch\u1EBFt nhanh ch\xF3ng."
  - speakerName: Player
    sentence: "\xD4ng c\xF3 th\u1EC3 r\xE8n l\u1EA1i n\xF3 ch\u1EE9? T\xF4i c\u1EA7n
      n\xF3 \u0111\u1EC3 c\u1EE9u Aria."
  - speakerName: Kael
    sentence: "\u0110\u01B0\u1EE3c, nh\u01B0ng ta c\u1EA7n than t\u1EEB h\u1EA7m
      ng\u1EE5c ph\xEDa \u0110\xF4ng. Ng\u01B0\u01A1i d\xE1m \u0111i kh\xF4ng?"
  delayBetweenLines: 3
  dialoguePanel: {fileID: 0}
  dialogueText: {fileID: 0}
